# Django
SECRET_KEY=згенеруй_на_https://djecrety.ir
DJANGO_SETTINGS_MODULE=mysite.settings.prod
DJANGO_LOG_LEVEL=WARNING

# Postgres (локальна БД в Docker)
POSTGRES_DB=nnikiti
POSTGRES_USER=nnikiti
POSTGRES_PASSWORD=придумай_пароль
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Cloudinary (для фото)
CLOUD_NAME=
CLOUD_KEY=
CLOUD_SECRET=

# Google OAuth (можна залишити порожнім якщо не використовується)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# CORS - фронтенд URL
CORS_ALLOWED_ORIGINS=https://nnikiti.duckdns.org

# Завантаження дампу при першому старті (1 = завантажити, потім змінити на 0)
LOAD_FIXTURES=1

# Скидання пароля адміна при старті
ADMIN_PASSWORD=твій_пароль_адміна

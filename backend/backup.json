{
  "model": "core.faqtranslation",
  "pk": 1,
  "fields": {
    "language_code": "uk",
    "question": "Які документи потрібні для вступу до інституту?",
    "answer": "Потрібен атестат про повну загальну середню освіту, паспорт та сертифікати ЗНО або НМТ.",
    "master": 1
  }
},
{
  "model": "core.faqtranslation",
  "pk": 2,
  "fields": {
    "language_code": "en",
    "question": "What documents are required for admission to the institute?",
    "answer": "You need a high school diploma, a passport, and standardized test certificates (ZNO or NMT).",
    "master": 1
  }
},
{
  "model": "core.faqtranslation",
  "pk": 3,
  "fields": {
    "language_code": "uk",
    "question": "Чи є в інституті гуртожиток?",
    "answer": "Так, інститут надає місця у гуртожитку для іногородніх студентів.",
    "master": 2
  }
},
{
  "model": "core.faqtranslation",
  "pk": 4,
  "fields": {
    "language_code": "en",
    "question": "Does the institute provide dormitory accommodation?",
    "answer": "Yes, the institute offers dormitory places for non-local students.",
    "master": 2
  }
},
{
  "model": "core.faqtranslation",
  "pk": 5,
  "fields": {
    "language_code": "uk",
    "question": "Які спеціальності доступні для навчання?",
    "answer": "Інститут пропонує спеціальності у сфері ІТ, економіки, права, інженерії та гуманітарних наук.",
    "master": 3
  }
},
{
  "model": "core.faqtranslation",
  "pk": 6,
  "fields": {
    "language_code": "en",
    "question": "What majors are available at the institute?",
    "answer": "The institute offers programs in IT, economics, law, engineering, and humanities.",
    "master": 3
  }
},
{
  "model": "core.faqtranslation",
  "pk": 7,
  "fields": {
    "language_code": "uk",
    "question": "Чи можна навчатися заочно?",
    "answer": "Так, є як денна, так і заочна форма навчання.",
    "master": 4
  }
},
{
  "model": "core.faqtranslation",
  "pk": 8,
  "fields": {
    "language_code": "en",
    "question": "Is part-time study available?",
    "answer": "Yes, both full-time and part-time study options are available.",
    "master": 4
  }
},
{
  "model": "core.faqtranslation",
  "pk": 9,
  "fields": {
    "language_code": "uk",
    "question": "Якою мовою ведеться навчання?",
    "answer": "Навчання ведеться українською мовою, але деякі програми доступні англійською.",
    "master": 5
  }
},
{
  "model": "core.faqtranslation",
  "pk": 10,
  "fields": {
    "language_code": "en",
    "question": "What is the language of instruction?",
    "answer": "The primary language is Ukrainian, but some programs are available in English.",
    "master": 5
  }
},
{
  "model": "core.faqtranslation",
  "pk": 11,
  "fields": {
    "language_code": "uk",
    "question": "Чи є можливість отримати стипендію?",
    "answer": "Так, академічна стипендія надається за високі результати в навчанні.",
    "master": 6
  }
},
{
  "model": "core.faqtranslation",
  "pk": 12,
  "fields": {
    "language_code": "en",
    "question": "Can I get a scholarship?",
    "answer": "Yes, academic scholarships are available for high-performing students.",
    "master": 6
  }
},
{
  "model": "core.faqtranslation",
  "pk": 13,
  "fields": {
    "language_code": "uk",
    "question": "Як подати документи онлайн?",
    "answer": "Ви можете подати документи через електронний кабінет вступника на офіційному сайті.",
    "master": 7
  }
},
{

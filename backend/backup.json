{
  "model": "core.alumnustranslation",
  "pk": 3,
  "fields": {
    "language_code": "uk",
    "full_name": "Чін Чіл Чінчілович",
    "text": "Чін Чіл, студент-програміст з невеликого українського міста, завжди мріяв про велике. Після випуску з університету, де він відзначився своїми новаторськими ідеями в галузі штучного інтелекту, він відправився до Каліфорнії. Там він приєднався до Google як рядовий інженер. Завдяки своїй винятковій працездатності, глибоким знанням та унікальному баченню майбутнього технологій, Ілон швидко піднявся кар'єрними сходами. Він очолив кілька ключових проєктів, які змінили підхід компанії до пошукових алгоритмів та аналізу даних. Його сміливість в ухваленні рішень і здатність надихати команду зрештою привели його до найвищої посади. У 35 років Ілон став головою CEO Google, довівши, що амбіції, талант і наполеглива праця можуть подолати будь-які межі.",
    "major": "Інженерія програмного забезпечення",
    "degree": "Магістр",
    "workplace": "Google",
    "position": "Голова CEO відділу",
    "master": 3
  }
},
